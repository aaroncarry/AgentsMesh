# docker image tag
BACKEND_VERSION=
WEB_VERSION=
WEB_ADMIN_VERSION=
RELAY_VERSION=

# server config
SERVER_HOST=__SERVER_HOST__
PRIMARY_DOMAIN=__PRIMARY_DOMAIN__
HTTP_PORT=80
GRPC_PORT=9443

COMPOSE_PROJECT_NAME=agentsmesh

# secrets
DB_PASSWORD=__CHANGE_ME__
JWT_SECRET=__CHANGE_ME__
INTERNAL_API_SECRET=__CHANGE_ME__
MINIO_ROOT_PASSWORD=__CHANGE_ME__

# storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# email config
EMAIL_PROVIDER=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# nginx config
NGINX_CONF_FILE=./nginx/nginx-test.conf