# AgentMesh GraphQL Schema

scalar Time
scalar JSON

# =============================================================================
# Types
# =============================================================================

type User {
  id: ID!
  email: String!
  username: String!
  name: String
  avatarURL: String
  isActive: Boolean!
  lastLoginAt: Time
  createdAt: Time!
  updatedAt: Time!
  organizations: [Organization!]!
}

type Organization {
  id: ID!
  name: String!
  slug: String!
  logoURL: String
  subscriptionPlan: String!
  subscriptionStatus: String!
  createdAt: Time!
  updatedAt: Time!
  members: [OrganizationMember!]!
  runners: [Runner!]!
}

type OrganizationMember {
  id: ID!
  user: User!
  role: String!
  joinedAt: Time!
}

type AgentType {
  id: ID!
  slug: String!
  name: String!
  description: String
  launchCommand: String!
  defaultArgs: String
  credentialSchema: JSON
  isBuiltin: Boolean!
  isActive: Boolean!
}

type CustomAgentType {
  id: ID!
  slug: String!
  name: String!
  description: String
  launchCommand: String!
  defaultArgs: String
  credentialSchema: JSON
  statusDetection: JSON
  isActive: Boolean!
}

type Runner {
  id: ID!
  nodeID: String!
  description: String
  status: RunnerStatus!
  lastHeartbeat: Time
  currentPods: Int!
  maxConcurrentPods: Int!
  runnerVersion: String
  hostInfo: JSON
  createdAt: Time!
  updatedAt: Time!
  activePods: [Pod!]!
}

enum RunnerStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

type Pod {
  id: ID!
  podKey: String!
  status: PodStatus!
  agentStatus: String!
  startedAt: Time
  finishedAt: Time
  lastActivity: Time
  initialPrompt: String
  branchName: String
  worktreePath: String
  createdAt: Time!
  updatedAt: Time!
  runner: Runner!
  agentType: AgentType
  repository: Repository
  ticket: Ticket
  createdBy: User!
}

enum PodStatus {
  INITIALIZING
  RUNNING
  PAUSED
  TERMINATED
  FAILED
}

type Repository {
  id: ID!
  name: String!
  fullPath: String!
  defaultBranch: String!
  ticketPrefix: String
  providerType: String!
  providerBaseURL: String!
  cloneURL: String!
  visibility: String!
  isActive: Boolean!
  createdAt: Time!
  updatedAt: Time!
}

type GitProvider {
  id: ID!
  providerType: String!
  name: String!
  baseURL: String!
  isDefault: Boolean!
  isActive: Boolean!
}

type Ticket {
  id: ID!
  number: Int!
  identifier: String!
  type: TicketType!
  title: String!
  description: String
  content: String
  status: TicketStatus!
  priority: TicketPriority!
  dueDate: Time
  startedAt: Time
  completedAt: Time
  createdAt: Time!
  updatedAt: Time!
  reporter: User!
  assignees: [User!]!
  labels: [Label!]!
  pods: [Pod!]!
  mergeRequests: [MergeRequest!]!
  childTickets: [Ticket!]!
  parentTicket: Ticket
}

enum TicketType {
  TASK
  BUG
  FEATURE
  EPIC
}

enum TicketStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TicketPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

type Label {
  id: ID!
  name: String!
  color: String!
}

type MergeRequest {
  id: ID!
  mrIID: Int!
  mrURL: String!
  sourceBranch: String!
  targetBranch: String!
  title: String
  state: String!
  createdAt: Time!
  updatedAt: Time!
}

type Channel {
  id: ID!
  name: String!
  description: String
  document: String
  isArchived: Boolean!
  createdAt: Time!
  updatedAt: Time!
  messages(limit: Int, offset: Int): [ChannelMessage!]!
  pods: [Pod!]!
}

type ChannelMessage {
  id: ID!
  content: String!
  messageType: String!
  metadata: JSON
  createdAt: Time!
  pod: Pod
  user: User
}

# Pagination
type PageInfo {
  hasNextPage: Boolean!
  hasPreviousPage: Boolean!
  startCursor: String
  endCursor: String
}

type TicketConnection {
  edges: [TicketEdge!]!
  pageInfo: PageInfo!
  totalCount: Int!
}

type TicketEdge {
  node: Ticket!
  cursor: String!
}

type PodConnection {
  edges: [PodEdge!]!
  pageInfo: PageInfo!
  totalCount: Int!
}

type PodEdge {
  node: Pod!
  cursor: String!
}

# =============================================================================
# Inputs
# =============================================================================

input CreateTicketInput {
  repositoryID: ID!
  type: TicketType!
  title: String!
  description: String
  content: String
  priority: TicketPriority
  assigneeIDs: [ID!]
  labels: [String!]
  parentID: ID
  dueDate: Time
}

input UpdateTicketInput {
  title: String
  description: String
  content: String
  type: TicketType
  status: TicketStatus
  priority: TicketPriority
  assigneeIDs: [ID!]
  labels: [String!]
  dueDate: Time
}

input CreatePodInput {
  runnerID: ID!
  agentTypeID: ID
  customAgentTypeID: ID
  repositoryID: ID
  ticketID: ID
  initialPrompt: String
  branchName: String
}

input CreateChannelInput {
  name: String!
  description: String
  document: String
  repositoryID: ID
  ticketID: ID
}

input UpdateChannelInput {
  name: String
  description: String
  document: String
}

input TicketFilter {
  repositoryID: ID
  status: TicketStatus
  priority: TicketPriority
  type: TicketType
  assigneeID: ID
  labels: [String!]
  search: String
}

input PodFilter {
  runnerID: ID
  status: PodStatus
  ticketID: ID
}

# =============================================================================
# Queries
# =============================================================================

type Query {
  # User
  me: User!
  user(id: ID!): User

  # Organization
  organization(slug: String!): Organization
  myOrganizations: [Organization!]!

  # Runners
  runner(id: ID!): Runner
  runners(status: RunnerStatus): [Runner!]!
  availableRunners: [Runner!]!

  # Pods
  pod(key: String!): Pod
  pods(filter: PodFilter, first: Int, after: String): PodConnection!

  # Agent Types
  agentTypes: [AgentType!]!
  agentType(id: ID!): AgentType
  customAgentTypes: [CustomAgentType!]!

  # Repositories
  repository(id: ID!): Repository
  repositories: [Repository!]!

  # Tickets
  ticket(identifier: String!): Ticket
  tickets(filter: TicketFilter, first: Int, after: String): TicketConnection!

  # Labels
  labels(repositoryID: ID): [Label!]!

  # Channels
  channel(id: ID!): Channel
  channels(includeArchived: Boolean): [Channel!]!

  # Git Providers
  gitProviders: [GitProvider!]!
}

# =============================================================================
# Mutations
# =============================================================================

type Mutation {
  # Pods
  createPod(input: CreatePodInput!): Pod!
  terminatePod(key: String!): Pod!

  # Tickets
  createTicket(input: CreateTicketInput!): Ticket!
  updateTicket(identifier: String!, input: UpdateTicketInput!): Ticket!
  deleteTicket(identifier: String!): Boolean!
  updateTicketStatus(identifier: String!, status: TicketStatus!): Ticket!

  # Labels
  createLabel(name: String!, color: String!, repositoryID: ID): Label!
  deleteLabel(id: ID!): Boolean!

  # Channels
  createChannel(input: CreateChannelInput!): Channel!
  updateChannel(id: ID!, input: UpdateChannelInput!): Channel!
  archiveChannel(id: ID!): Channel!
  unarchiveChannel(id: ID!): Channel!
  sendMessage(channelID: ID!, content: String!, podKey: String): ChannelMessage!

  # Channel Pod Management
  joinChannel(channelID: ID!, podKey: String!): Boolean!
  leaveChannel(channelID: ID!, podKey: String!): Boolean!
}

# =============================================================================
# Subscriptions
# =============================================================================

type Subscription {
  # Pod updates
  podUpdated(key: String!): Pod!

  # Channel messages
  messageReceived(channelID: ID!): ChannelMessage!

  # Runner status
  runnerStatusChanged: Runner!
}
